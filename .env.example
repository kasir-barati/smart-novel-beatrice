PORT=3000
SERVICE_NAME=smart-novel-beatrice

# -- Logging ----------------------------------------------------------------- #
LOGGING__MODE=JSON # JSON | PLAIN_TEXT
LOGGING__LEVEL=info

# -- OpenTelemetry ----------------------------------------------------------- #
OTEL__ENABLED=true
OTEL__EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL__TRACES_SAMPLER=parentbased_always_on

# -- Model backend (OpenAI-compatible endpoint) ------------------------------ #
LLM__BASE_URL=http://ollama:11434/v1
LLM__API_KEY=ollama # Ollama accepts any non-empty string; real providers need a real key
LLM__MODEL=qwen2.5:3b
LLM__TIMEOUT_MS=180000

# --------------------------------------------------------------------------- #
# Per-endpoint overrides (optional; leave unset to use LLM__* defaults above).
# --------------------------------------------------------------------------- #
# EXPLAIN_WORD__MODEL=
EXPLAIN_WORD__TEMPERATURE=0
# NORMALIZE_TTS__MODEL=
NORMALIZE_TTS__TEMPERATURE=0

# Build-time pull for the ollama compose service. Keep in sync with LLM__MODEL.
OLLAMA_MODEL=qwen2.5:3b
