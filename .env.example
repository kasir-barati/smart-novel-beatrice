PORT=3000
LOGGING_MODE=JSON # JSON | PRETTY
LOG_LEVEL=info
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
SERVICE_NAME=smart-novel-beatrice
OTEL_TRACES_SAMPLER=parentbased_always_on

# --------------------------------------------------------------------------- #
# Per-endpoint overrides (optional; leave unset to use the defaults above).
# --------------------------------------------------------------------------- #
# EXPLAIN_WORD_MODEL=
# EXPLAIN_WORD_TEMPERATURE=0.2
# NORMALIZE_TTS_MODEL=
# NORMALIZE_TTS_TEMPERATURE=0.1
LLM_BASE_URL=http://ollama:11434/v1
LLM_API_KEY=ollama # Ollama accepts any non-empty string; real providers need a real key
LLM_MODEL=llama3.2
LLM_TIMEOUT_MS=30000
